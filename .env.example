# Set these in Render's dashboard under your service > Environment.
# Do NOT put real values in a committed file.

# Full JSON contents of your Firebase service account key, as one line.
# Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"naveen-gpt", ...}

# ---- NVIDIA NIM (Nemotron — direct API, not through OpenRouter) ----
# Get your key at https://build.nvidia.com  (API Key → Generate Key)
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_MODEL=nvidia/nemotron-3-ultra-550b-a55b
NVIDIA_LABEL=Nemotron Ultra

# ---- OpenRouter (optional extra models) ----
# You can add up to 2 additional models here via OpenRouter.
# A slot is only shown in the frontend dropdown if BOTH its key and model are set.

OPENROUTER_API_KEY_1=PASTE_YOUR_OPENROUTER_KEY
OPENROUTER_MODEL_1=cohere/north-mini-code:free
OPENROUTER_LABEL_1=Cohere North Mini Code (free)

# ---- RAG embeddings (used by /api/ingest and retrieval in /api/chat) ----
# Defaults to slot 1's key if not set separately. Note: many free-tier
# models don't support embeddings — you may need a separate key/model here
# once you actually start ingesting study material.
OPENROUTER_EMBEDDING_API_KEY=PASTE_YOUR_OPENROUTER_KEY
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
