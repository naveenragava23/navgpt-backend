# Set these in Render's dashboard under your service > Environment.
# Do NOT put real values in a committed file.

# Full JSON contents of your Firebase service account key, as one line.
# Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"naveen-gpt", ...}

# ---- Up to 3 selectable OpenRouter models ----
# You can reuse the SAME OpenRouter API key for all three slots — one key
# can call any model OpenRouter offers, including free-tier ones like these.
# Only slots with BOTH a key and a model set will show up in the frontend
# dropdown.

OPENROUTER_API_KEY_1=PASTE_YOUR_OPENROUTER_KEY
OPENROUTER_MODEL_1=tencent/hy3:free
OPENROUTER_LABEL_1=Tencent HY3 (free)

OPENROUTER_API_KEY_2=PASTE_YOUR_OPENROUTER_KEY
OPENROUTER_MODEL_2=nvidia/nemotron-3-ultra-550b-a55b:free
OPENROUTER_LABEL_2=Nemotron 3 Ultra (free)

OPENROUTER_API_KEY_3=PASTE_YOUR_OPENROUTER_KEY
OPENROUTER_MODEL_3=cohere/north-mini-code:free
OPENROUTER_LABEL_3=Cohere North Mini Code (free)

# ---- RAG embeddings (used by /api/ingest and retrieval in /api/chat) ----
# Defaults to slot 1's key if not set separately. Note: many free-tier
# models don't support embeddings — you may need a separate key/model here
# once you actually start ingesting study material.
OPENROUTER_EMBEDDING_API_KEY=PASTE_YOUR_OPENROUTER_KEY
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
