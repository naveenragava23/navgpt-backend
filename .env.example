# Set these in Render's dashboard under your service > Environment.
# Do NOT put real values in a committed file.

# Full JSON contents of your Firebase service account key, as one line.
# Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"naveen-gpt", ...}

# Your NVIDIA API key — use the NEW regenerated one, never the old exposed one.
NVIDIA_API_KEY=PASTE_YOUR_NEW_NVIDIA_KEY_HERE

# Optional: override the default model
NVIDIA_MODEL=z-ai/glm-5.2
